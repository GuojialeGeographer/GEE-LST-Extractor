    "print(f\"📊 发现 {total_updates} 个可用更新\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "if total_updates > 0:\n",
    "    print(\"\\n✨ 太棒了！发现了新版本数据集！\")\n",
