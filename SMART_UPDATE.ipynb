   "source": [
    "# ============================================================\n",
    "# 生成智能推荐\n",
    "# ============================================================\n",
    "\n",
    "recommendations = updater.generate_update_recommendations()\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"💡 智能推荐完成！\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "if recommendations:\n",
    "    print(\"\\n📋 推荐总结:\")\n",
    "    for i, rec in enumerate(recommendations, 1):\n",
    "        print(f\"\\n{i}. {rec['dataset']}:\")\n",
    "        print(f\"   更新: {rec['from_version']} → {rec['to_version']}\")\n",
    "        print(f\"   优先级: {rec['priority']}\")\n",
    "else:\n",
    "    print(\"\\n✅ 无需更新，所有数据集都是最新版本\")"
   ]
