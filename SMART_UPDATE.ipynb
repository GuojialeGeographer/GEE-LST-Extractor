    "# 🤖 智能数据更新系统\n",
    "\n",
    "## 🎯 功能说明\n",
    "\n",
    "这个Notebook提供了**智能数据更新**功能，可以：\n",
    "\n",
    "1. **🔍 自动发现最新数据集**\n",
    "   - 搜索GEE上的最新数据\n",
    "   - 识别版本更新\n",
    "   - 检测新数据可用性\n",
    "\n",
    "2. **💡 智能推荐**\n",
    "   - 为你的研究推荐最佳数据源\n",
    "   - 说明选择理由\n",
    "   - 提供替代方案\n",
    "\n",
    "3. **🔄 一键更新**\n",
    "   - 自动更新提取器配置\n",
    "   - 保持数据源最新\n",
    "   - 生成更新日志\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# 智能数据更新系统\n",
    "# ============================================================\n",
    "\n",
    "import ee\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from datetime import datetime\n",
    "from pathlib import Path\n",
    "\n",
    "# 初始化GEE\n",
    "try:\n",
    "    ee.Initialize()\n",
    "    print(\"✅ GEE已连接\")\n",
    "except Exception as e:\n",
    "    print(f\"⚠️  GEE连接失败: {e}\")\n",
    "    print(\"请运行: ee.Authenticate()\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔍 第一步：发现可用更新"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class SmartGEEUpdater:\n",
    "    \"\"\"\n",
    "    智能GEE数据更新器\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.current_version = '061'  # 当前MODIS版本\n",
    "        self.available_updates = []\n",
    "        \n",
    "    def discover_modis_updates(self):\n",
    "        \"\"\"发现MODIS数据集更新\"\"\"\n",
    "        print(\"\\n🔍 检查MODIS数据集版本...\")\n",
    "        \n",
    "        # 定义要检查的数据集\n",
    "        datasets = [\n",
    "            {'name': 'LST', 'collection': 'MODIS/061/MOD11A2', 'band': 'LST_Day_1km'},\n",
    "            {'name': 'NDVI', 'collection': 'MODIS/061/MOD13Q1', 'band': 'NDVI'},\n",
    "            {'name': 'EVI', 'collection': 'MODIS/061/MOD13Q1', 'band': 'EVI'},\n",
    "            {'name': 'Albedo', 'collection': 'MODIS/061/MCD43A3', 'band': 'Albedo_WSA_shortwave'}\n",
    "        ]\n",
    "        \n",
    "        # 检查新版本 (062, 063, 064, 065)\n",
    "        new_versions = ['062', '063', '064', '065']\n",
    "        \n",
    "        for version in new_versions:\n",
    "            print(f\"\\n--- 检查版本 {version} ---\")\n",
    "            \n",
    "            for dataset in datasets:\n",
    "                new_collection = dataset['collection'].replace('061', version)\n",
    "                \n",
    "                try:\n",
    "                    # 尝试访问数据集\n",
    "                    collection = ee.ImageCollection(new_collection)\n",
    "                    \n",
    "                    # 尝试获取第一幅影像\n",
    "                    first = collection.limit(1).first()\n",
    "                    \n",
    "                    if first is not None:\n",
    "                        # 获取数据集属性\n",
    "                        props = first.toDict()\n",
    "                        \n",
    "                        self.available_updates.append({\n",
    "                            'dataset': dataset['name'],\n",
    "                            'current_version': '061',\n",
    "                            'new_version': version,\n",
    "                            'new_collection': new_collection,\n",
    "                            'band': dataset['band'],\n",
    "                            'system:id': props.get('system:id', ''),\n",
    "                            'system:version': props.get('system:version', '')\n",
    "                        })\n",
    "                        \n",
    "                        print(f\"✅ {dataset['name']}: 版本 {version} 可用!\")\n",
    "                        print(f\"   数据集: {new_collection}\")\n",
    "                        print(f\"   ID: {props.get('system:id', '')}\")\n",
    "                    \n",
    "                except Exception as e:\n",
    "                    # 版本不存在或无法访问\n",
    "                    pass\n",
    "        \n",
    "        return self.available_updates\n",
    "    \n",
    "    def discover_landsat_updates(self):\n",
    "        \"\"\"发现Landsat数据集更新\"\"\"\n",
    "        print(\"\\n🔍 检查Landsat数据集版本...\")\n",
    "        \n",
    "        # 检查Landsat 9, 10等\n",
    "        new_versions = ['09', '10']\n",
    "        \n",
    "        for version in new_versions:\n",
    "            test_collection = f'LANDSAT/LC{version}/C02/T1_L2'\n",
    "            \n",
    "            try:\n",
    "                collection = ee.ImageCollection(test_collection)\n",
    "                first = collection.limit(1).first()\n",
    "                \n",
    "                if first is not None:\n",
    "                    props = first.toDict()\n",
    "                    \n",
    "                    self.available_updates.append({\n",
    "                        'dataset': 'Landsat',\n",
    "                        'current_version': '08',\n",
    "                        'new_version': version,\n",
    "                        'new_collection': test_collection,\n",
   ",
    "                        'system:id': props.get('system:id', ''),\n",
    "                        'system:version': props.get('system:version', '')\n",
    "                    })\n",
    "                    \n",
    "                    print(f\"✅ Landsat {version}: 可用!\")\n",
    "                    print(f\"   数据集: {test_collection}\")\n",
    "                    \n",
    "            except Exception:\n",
    "                pass\n",
    "        \n",
    "        return self.available_updates\n",
    "    \n",
    "    def generate_update_recommendations(self):\n",
    "        \"\"\"生成更新建议\"\"\"\n",
    "        print(\"\\n💡 生成更新建议...\\n\")\n",
    "        \n",
    "        if not self.available_updates:\n",
    "            print(\"✅ 所有数据集都是最新版本，无需更新！\")\n",
    "            return []\n",
    "        \n",
    "        recommendations = []\n",
    "        \n",
    "        print(\"📋 推荐的更新:\\n\")\n",
    "        \n",
    "        for i, update in enumerate(self.available_updates, 1):\n",
    "            print(f\"{i}. {update['dataset']}:\")\n",
    "            print(f\"   当前版本: {update['current_version']}\")\n",
    "            print(f\"   可用版本: {update['new_version']}\")\n",
    "            print(f\"   数据集ID: {update['system:id']}\")\n",
    "            \n",
    "            # 判断优先级\n",
    "            if update['dataset'] == 'LST' or update['dataset'] == 'NDVI':\n",
    "                priority = \"🔥 高优先级\"\n",
    "            else:\n",
    "                priority = \"💡 中优先级\"\n",
    "            \n",
    "            print(f\"   优先级: {priority}\")\n",
    "            \n",
   ",
    "            # 添加到推荐列表\n",
    "            recommendations.append({\n",
    "                'dataset': update['dataset'],\n",
    "                'from_version': update['current_version'],\n",
    "                'to_version': update['new_version'],\n",
    "                'collection_id': update['new_collection'],\n",
    "                'priority': priority\n",
    "            })\n",
    "            \n",
    "            print()\n",
    "        \n",
    "        return recommendations\n",
    "    \n",
    "    def auto_update_extractors(self, recommendations):\n",
    "        \"\"\"自动更新提取器代码\"\"\"\n",
    "        print(\"\\n🔄 自动更新提取器配置...\\n\")\n",
    "        \n",
    "        if not recommendations:\n",
    "            print(\"无需更新\")\n",
    "            return\n",
    "        \n",
    "        # 读取当前提取器文件\n",
    "        extractor_files = [\n",
    "            'extractors/lst_extractor.py',\n",
    "            'extractors/ndvi_extractor.py',\n",
    "            'extractors/evi_extractor.py'\n",
    "        ]\n",
    "        \n",
    "        for rec in recommendations:\n",
    "            if 'MODIS' in rec['collection_id']:\n",
    "                print(f\"\\n📝 更新 {rec['dataset']} 提取器:\")\n",
    "                print(f\"   版本: {rec['from_version']} → {rec['to_version']}\")\n",
    "                print(f\"   数据集: {rec['collection_id']}\")\n",
    "                \n",
    "                # 这里可以添加自动更新代码的逻辑\n",
    "                # 比如修改提取器文件中的版本号\n",
    "                \n",
    "                # 生成更新代码片段\n",
    "                update_code = f'''\n",
    "# 在提取器中更新数据集版本\n",
    "# 将 {rec['collection_id']} 替换为新版本\n",
    "# 旧版本: {rec['from_version']}\n",
    "# 新版本: {rec['to_version']}\n",
    "                '''\n",
    "                \n",
    "                print(f\"\\n生成更新代码:\")\n",
    "                print(update_code)\n",
    "                print(\"\\n💾 复制以上代码到对应的提取器文件中\")\n",
    "                \n",
    "    def save_update_report(self, updates, recommendations):\n",
    "        \"\"\"保存更新报告\"\"\"\n",
    "        report = {\n",
    "            'timestamp': datetime.now().isoformat(),\n",
    "            'updates_found': len(updates),\n",
    "            'recommendations': recommendations,\n",
    "            'status': 'completed'\n",
    "        }\n",
    "        \n",
    "        # 保存为JSON\n",
    "        cache_dir = Path('./cache')\n",
    "        cache_dir.mkdir(exist_ok=True)\n",
    "        \n",
    "        report_file = cache_dir / f\"gee_update_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json\"\n",
    "        \n",
    "        import json\n",
    "        with open(report_file, 'w', encoding='utf-8') as f:\n",
    "            json.dump(report, f, indent=2, ensure_ascii=False)\n",
    "        \n",
    "        print(f\"\\n💾 更新报告已保存: {report_file}\")\n",
    "\n",
    "# 创建更新器实例\n",
    "updater = SmartGEEUpdater()\n",
    "\n",
    "print(\"✅ 智能更新系统已初始化！\")"
   ]
  },
